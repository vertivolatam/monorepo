{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [".env"],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "build/**",
        ".dart_tool/**",
        "lib/src/generated/**"
      ]
    },
    "generate": {
      "outputs": [
        "lib/src/generated/**",
        "lib/src/protocol/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "migrate": {
      "cache": false
    }
  }
}
