# Vertivo — local dev environment template.
# COPY to `.env` (gitignored) and fill the real values for LOCAL development only.
# NEVER commit real values, and NEVER paste them into a chat/log.
#
# Scope: this file documents env vars for LOCAL DEV (NVIDIA NIM + AI vision stack).
# Other secret stores are kept where they already live — do NOT duplicate here:
#   - vertivo_server (Serverpod) DB/passwords -> apps/vertivo_server/config/passwords.yaml
#   - raspberry device vars (BALENA_*)         -> injected by Balena at runtime

# ===========================================================================
# NVIDIA build.nvidia.com — NIM hosted inference (vision-core / AI vision)
# ===========================================================================
# SERVER-SIDE ONLY. Never expose in any Flutter/web client bundle.
# Format: nvapi-...  (created at build.nvidia.com -> Settings -> API Keys).
# For LOCAL DEV use the "internal_staging" key (NOT public_prod).
#   - "public_prod" key lives only in the production deployment secret store,
#     never in a local .env.
NVIDIA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: default NIM models to call (override per use case).
# NVIDIA_NIM_DETECTION_MODEL=
# NVIDIA_NIM_VLM_MODEL=

# ===========================================================================
# vision-core service (chimeranext/better-microservices) — when run locally
# ===========================================================================
# vision-core reads the NVIDIA key under its own VISION_ prefix. If you run
# vision-core from this monorepo's local stack, mirror the value:
#   VISION_NVIDIA_API_KEY = same as NVIDIA_API_KEY (internal_staging, local)
VISION_NVIDIA_API_KEY=
